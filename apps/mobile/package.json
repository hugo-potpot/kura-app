{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo/ios",
    "roots": [
      "<rootDir>"
    ],
    "moduleDirectories": [
      "node_modules",
      "../../node_modules"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|react-native-qrcode-svg|react-native-draggable-flatlist|@ungap)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@kura/shared$": "<rootDir>/../../packages/shared/src/index.ts",
      "^@kura/db$": "<rootDir>/../../packages/db/schema/index.ts",
      "^react-native-maps$": "<rootDir>/test-utils/react-native-maps-stub.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/test-utils/async-storage-stub.js"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@kura/db": "workspace:^",
    "@kura/shared": "workspace:^",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/native": "^7.1.28",
    "@tanstack/react-query": "^5.90.21",
    "drizzle-orm": "^0.38.3",
    "expo": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-haptics": "~55.0.0",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "^55.0.9",
    "expo-network": "^55.0.9",
    "expo-router": "~55.0.5",
    "expo-secure-store": "^55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.0",
    "react-native": "0.83.2",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-maps": "1.27.2",
    "react-native-paper": "^5.15.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "sql.js": "^1.12.0",
    "ulidx": "^2.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@types/sql.js": "^1.4.9",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "typescript": "~5.9.2"
  },
  "private": true
}
